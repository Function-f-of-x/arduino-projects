profiles:
  STM32:
    fqbn: STMicroelectronics:stm32:GenF1:pnum=BLUEPILL_F103C6,xserial=generic,usb=none,xusb=FS,opt=oslto,dbg=none,rtlib=nanofp,upload_method=OpenOCDSTLink
    platforms:
      - platform: STMicroelectronics:stm32 (2.12.0)
        platform_index_url: https://github.com/stm32duino/BoardManagerFiles/raw/main/package_stmicroelectronics_index.json
    programmer: ""
    port_config:
      baudrate: "115200"
      lineEnding: "\r\n"
      bits: "8"
      parity: none
      stop_bits: "1"
    port: COM26
