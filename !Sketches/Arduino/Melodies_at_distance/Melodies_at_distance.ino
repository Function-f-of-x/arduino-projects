void setup() {
  Serial.begin(9600);
  pinMode(buzzer, OUTPUT);
}

void loop() {
  distance = ultrasonic.read();
  if (distance < 10) {
    for (int i = 0; i < 39; i++){
      tone(buzzer, starNotes[i], starTimes[i]*2);
      delay(starTimes[i]*2);
      noTone(buzzer);
    }
    delay(500);
  } else if (distance < 30) {
      for (int i = 0; i < 29; i++){
        tone(buzzer, treeNotes[i], treeTimes[i]);
        delay(treeTimes[i]);
        noTone(buzzer);
      }
  } else if (distance < 50) {
      for (int i = 0; i < 75; i++){
        tone(buzzer, marioNotes[i], marioTimes[i]);
        delay(marioDelays[i]);
      }
      noTone(buzzer);
  }
}
